# ExpensIQ — Environment Variables
# Copy this file: cp .env.example .env

# Database
POSTGRES_DB=expensiq
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/expensiq

# MinIO (S3-compatible storage)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=expensiq-receipts
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# OCR Provider: "mock" (demo) or "claude" (real AI)
OCR_PROVIDER=mock

# Anthropic API (required when OCR_PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Banking Provider: "mock" (demo)
BANKING_PROVIDER=mock

# CORS
CORS_ORIGINS=["http://localhost:8000", "http://localhost:3000"]

# App
APP_ENV=development

# Platform (set to linux/amd64 on Mac ARM64 with Colima/Rosetta)
DOCKER_DEFAULT_PLATFORM=linux/amd64
